};

# rex show_keys                     ; list all stored key metadata
# rex show_keys --machine=<name>    ; show decrypted key for a specific machine
# Requires: ClusterDB module, CLUSTER_DB_KEY env var or keyfile
desc "List SSH public keys stored in the encrypted database";
task "show_keys", sub {
    die "ClusterDB module not available.\n"
      . "Install: cpan CryptX DBI DBD::SQLite\n"
      unless $HAS_CLUSTER_DB;
    my $db = cluster_db()
      or die "Key database not accessible.\n"
      . "Set CLUSTER_DB_KEY env var or create keyfile.\n";

    my $param   = shift || {};
    my $machine = $param->{machine};

    if ($machine) {
        validate_name($machine);
        my @keys = $db->get_key( machine => $machine );
        if ( !@keys ) {
            say "No keys found for machine '$machine'.";
            return;
        }
        say "=" x 70;
        say "Keys for: $machine";
        say "=" x 70;
        for my $k (@keys) {
            say "Key Type    : $k->{key_type}";
            say "Fingerprint : $k->{fingerprint}" if $k->{fingerprint};
            say "Created     : $k->{created_at}";
            say "Rotated     : $k->{rotated_at}" if $k->{rotated_at};
            say "Public Key  : $k->{public_key}";
            say "-" x 70;
        }
    }
    else {
        my @keys = $db->list_keys;
        say "=" x 70;
        say "Stored SSH Public Keys";
        say "=" x 70;
        printf "%-20s %-26s %-12s %s\n",
          'Machine', 'Key Type', 'Created', 'Fingerprint';
        say "-" x 70;
        for my $k (@keys) {
            printf "%-20s %-26s %-12s %s\n",
              $k->{machine}, $k->{key_type},
              substr( $k->{created_at}  // '', 0, 10 ),
              substr( $k->{fingerprint} // '', 0, 20 );
        }
        say "=" x 70;
        say "Total: " . scalar(@keys) . " key(s)";
    }
    audit_log( 'show_keys', machine => $machine // 'all' );
};

