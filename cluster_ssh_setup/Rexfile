# rex show_cmdb                      ; show all machines (passwords redacted)
# rex show_cmdb --group=<name>       ; show only machines in a named group
desc "Display network and machine information from the CMDB";
task "show_cmdb", sub {
    my $param      = shift || {};
    my $group_name = $param->{group} // 'all';

    die "Group '$group_name' is not defined.\n"
      unless Rex::Group->is_group($group_name);
    my @group_members = Rex::Group->get_group($group_name);

    say "=" x 60;
    say "CMDB Machine & Network Information (group: $group_name)";
    say "=" x 60;
    for my $machine ( sort @group_members ) {
        my $networks = get cmdb( 'networks', $machine );
        my ( $username, undef ) = get_credential($machine);
        say "\nMachine  : $machine";
        say "Username : " . ( $username // '(not set)' );
        say "Password : (redacted - SEC-CRED-REDACT)";
        say "Networks :";
        for my $net ( sort keys %{$networks} ) {
            printf "  %-10s %s\n", $net, $networks->{$net};
        }
    }
    say "\n" . "=" x 60;
};

# rex list_groups                     ; list all defined inventory groups and their members
