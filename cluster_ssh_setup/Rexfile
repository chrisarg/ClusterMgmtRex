# ---------------------------------------------------------------------------
# Security Practice Labels & FIPS-140 Compliance Configuration
# ---------------------------------------------------------------------------
# This Rexfile follows DISA-STIG-aligned security practices. The V-238xxx
# rule IDs belong to the Ubuntu 20.04 LTS STIG and do not apply to 22.04.
# Instead, the practices below are labelled with descriptive security tags:
#
#   [SEC-SSH-NOPASSWD]    Password authentication disabled (key-based only)
#   [SEC-STRICT-HOSTKEY]  StrictHostKeyChecking enforced (except bootstrap)
#   [SEC-FIPS-ALGO]       SSH key generation uses FIPS-approved algorithms
#   [SEC-CRED-ENCRYPT]    No plaintext credentials in process table or on disk
#   [SEC-AUDIT-LOG]       All mutating operations produce audit log entries
#   [SEC-CRED-REDACT]     Credentials not displayed to terminal
#   [SEC-KEY-PASSPHRASE]  SSH keys protected with random passphrase
#   [SEC-SSH-CONFIG-PERMS] SSH config file permissions enforced to 0600
#   [FIPS-140]            Only NIST-approved algorithms for keyscan/keygen
#
# Operational modes:
#   - Bootstrap (--bootstrap=1): For initial key distribution only.
#     Uses SSH_ASKPASS + 0400 tempfile for password handling (never in
#     process table or /proc/environ; [SEC-CRED-ENCRYPT]).
#     Requires explicit opt-in. Host key checking relaxed.
#   - Operational (default): Key-based SSH with strict host checking.
#     No passwords needed or used. The cluster key must already exist.
#
# Prerequisites:
#   - sudoers NOPASSWD rules for the cluster service account:
#       /usr/sbin/shutdown (or /sbin/shutdown) -- for the shutdown task
#       /usr/bin/tee /etc/hosts                -- for /etc/hosts updates
#   - SSH keys deployed via setup_ssh_keys --bootstrap=1 before other tasks
# ---------------------------------------------------------------------------

# FIPS-approved key types for ssh-keyscan (NIST SP 800-131A Rev.2)
my $FIPS_KEYSCAN_TYPES =
  'ecdsa-sha2-nistp256,ecdsa-sha2-nistp384,ecdsa-sha2-nistp521';

# Audit log for all mutating operations
my $audit_log_path = abs_path('../logs/audit.log');

# Admin SSH key path (used for operational admin -> node connections)
my $cluster_key_path = ( $ENV{HOME} // '.' ) . '/.ssh/id_ecdsa_p521_cluster';

# Encrypted key database paths [SEC-CRED-ENCRYPT]
my $createdatabase_dir = abs_path('../createdatabase') // '../createdatabase';
my $cluster_db_path    = "$createdatabase_dir/cluster_keys.db";
my $cluster_db_keyfile = "$createdatabase_dir/.cluster_db.keyfile";

# Configure Rex to use sudo globally for tasks
#sudo TRUE;

#1. Enumerate machine names from the cmdb directory at load time
my $cmdb_dir    = abs_path('../cmdb');
my @yml_files   = glob("$cmdb_dir/*.yml");
my @machines    = map { basename( $_, '.yml' ) } @yml_files;
my %machine_set = map { $_ => 1 } @machines;

# Validate machine names to prevent shell injection (OWASP A03:2021)
for my $name (@machines) {
    die "Invalid machine name '$name': must match /^[a-zA-Z0-9._-]+\$/\n"
      unless $name =~ /^[a-zA-Z0-9._-]+$/;
}

#2. Configure Rex::CMDB
set cmdb => {
    type           => 'YAML',
    path           => $cmdb_dir,
    merge_behavior => 'LEFT_PRECEDENT',
};

#3. Centralized group definitions for scalable inventory management.
#   Add or modify groups here as inventory needs grow.
my %group_defs = ( all => [ sort @machines ], );

for my $group_name ( sort keys %group_defs ) {
    my @members = grep { $machine_set{$_} } @{ $group_defs{$group_name} };
    group $group_name => @members;
}

# Default SSH connection retry count (overridable per-task via --ssh_retry=N)
my $DEFAULT_SSH_RETRY = 5;

# ---------------------------------------------------------------------------
# Initialize shared helpers (ClusterSSHHelpers)
